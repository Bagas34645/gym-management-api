APP_NAME=CoreGym
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=gym_management_api
DB_USERNAME=postgres
DB_PASSWORD=

# MongoDB (weather analytics — must match big-data-coregym DATABASE_NAME)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=coregym_weather

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=gym-management
REVERB_APP_KEY=gym_reverb_key_654
REVERB_APP_SECRET=gym_reverb_secret_654
REVERB_HOST=localhost
REVERB_PORT=8081
REVERB_SCHEME=http
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

JWT_PRIVATE_KEY_PATH=storage/app/jwt/private.pem
JWT_PUBLIC_KEY_PATH=storage/app/jwt/public.pem
JWT_ACCESS_TTL=86400
JWT_REFRESH_TTL=2592000

FACE_API_URL=http://localhost:8001
FACE_API_KEY=dev-face-key
FACE_VERIFY_THRESHOLD=0.6
FACE_IDENTIFY_THRESHOLD=0.45
# Dedicated key for face embedding encryption (recommended in production).
# Falls back to APP_KEY when empty.
FACE_ENCRYPTION_KEY=

KIOSK_API_KEY=dev-kiosk-key

# Path ke file service account Firebase Admin SDK (relatif dari base path proyek)
FIREBASE_CREDENTIALS=storage/app/firebase/service-account.json

OTP_TTL=300
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

MIDTRANS_MERCHANT_ID=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# Swagger / OpenAPI (l5-swagger)
L5_SWAGGER_GENERATE_ALWAYS=false
L5_FORMAT_TO_USE_FOR_DOCS=yaml
L5_SWAGGER_UI_PERSIST_AUTHORIZATION=true
